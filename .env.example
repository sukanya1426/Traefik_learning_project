# =============================================================================
# Copy this file to .env and fill in your values before deploying.
# .env is gitignored — never commit it.
# =============================================================================

# Your domain name. DNS A records must point to your server IP.
# Example: if DOMAIN=example.com, you need:
#   api.example.com     → 37.27.203.157
#   traefik.example.com → 37.27.203.157
DOMAIN=yourdomain.com

# Email for Let's Encrypt certificate expiry notifications
LETSENCRYPT_EMAIL=you@example.com

# Basic auth for the Traefik dashboard
# Generate with:
#   htpasswd -nB admin | sed 's/\$/\$\$/g'
# Example (admin / admin123) — CHANGE THIS:
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$replaceme

# Basic auth for the FastAPI
# Generate with:
#   htpasswd -nB user | sed 's/\$/\$\$/g'
# Example (user / password123) — CHANGE THIS:
API_AUTH=user:$$2y$$05$$replaceme
